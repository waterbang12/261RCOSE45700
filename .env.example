# OpenAI
OPENAI_API_KEY=your_openai_api_key
VISION_MODEL=gpt-4o-mini
TTS_MODEL=tts-1
TTS_VOICE=nova

# 환경 제어 API (온도/조명/팬)
ENV_CONTROL_API_URL=http://localhost:8000
ENV_CONTROL_API_KEY=your_env_api_key

# SMS (Solapi)
SMS_API_URL=https://api.solapi.com/messages/v4/send
SMS_API_KEY=your_solapi_key
SENDER_PHONE=010-0000-0000
MANAGER_PHONE=010-0000-0000

# 앱 푸시 웹훅
PUSH_WEBHOOK=http://localhost:9000/push

# DB
DB_PATH=golf.db

# 영업 시간 (24h 형식)
OPEN_HOUR=9
CLOSE_HOUR=22
