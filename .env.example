# OpenAI
OPENAI_API_KEY=your_openai_api_key
VISION_MODEL=gpt-5-mini
ESCALATION_MODEL=gpt-5
ORCHESTRATOR_MODEL=gpt-5-mini
CUSTOMER_MODEL=gpt-5-mini
REPORT_MODEL=gpt-5-mini
TTS_MODEL=tts-1
TTS_VOICE=nova
STT_MODEL=whisper-1
STT_LANGUAGE=ko

# 환경 제어 API (온도/조명/팬)
ENV_CONTROL_API_URL=http://localhost:8000
ENV_CONTROL_API_KEY=your_env_api_key

# SMS (Solapi)
SMS_API_URL=https://api.solapi.com/messages/v4/send
SMS_API_KEY=your_solapi_key
SENDER_PHONE=010-0000-0000
MANAGER_PHONE=010-0000-0000

# 앱 푸시 웹훅
PUSH_WEBHOOK=http://localhost:9000/push

# DB
DB_PATH=golf.db

# 영업 시간 (24h 형식)
OPEN_HOUR=9
CLOSE_HOUR=22

# 카메라 소스 (main.py)
#  - TAPO_RTSP_URL 설정 시 1번 구역은 IP 카메라(RTSP) 사용
#  - 미설정 시 ZONE1_CAMERA_INDEX(USB 웹캠 인덱스) 사용
#  - ZONE2/3는 값이 있을 때만 해당 구역 카메라 활성화
TAPO_RTSP_URL=
ZONE1_CAMERA_INDEX=0
ZONE2_CAMERA_INDEX=
ZONE3_CAMERA_INDEX=

# OpenCV 디버그 창 / 데이터 트레이스 로그 (1=on, 0=off)
DEBUG_CAMERA=1
TRACE_CAMERA_DATA=1

# Arduino 액추에이터 (데모용 — 1=on, pyserial 필요)
ARDUINO_ENABLED=0
ARDUINO_PORT=COM3
ARDUINO_BAUD=9600
